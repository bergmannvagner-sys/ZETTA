{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://zetta-bergmann.onrender.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "APP_ENV": "production",
        "NODE_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://zetta-bergmann.onrender.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
